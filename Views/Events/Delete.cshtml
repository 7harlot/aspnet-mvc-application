@model assignment_1.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h2 class="mb-0">🗑️ Delete Event</h2>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <h4>⚠️ Are you sure you want to delete this event?</h4>
                    <p class="mb-0">This action cannot be undone.</p>
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>

                    <dt class="col-sm-3">Category</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Category.Name)</dd>

                    <dt class="col-sm-3">Date & Time</dt>
                    <dd class="col-sm-9">@Model.DateTime.ToString("MMMM dd, yyyy - hh:mm tt")</dd>

                    <dt class="col-sm-3">Ticket Price</dt>
                    <dd class="col-sm-9">$@Model.TicketPrice.ToString("F2")</dd>

                    <dt class="col-sm-3">Available Tickets</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.AvailableTickets)</dd>
                </dl>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="EventId"/>
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Delete Event</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>