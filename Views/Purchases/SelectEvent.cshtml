@model IEnumerable<assignment_1.Models.Event>

@{
    ViewData["Title"] = "Select Event";
}

<div class="row mb-4">
    <div class="col-md-12">
        <h1 class="display-4">🎫 Buy Tickets</h1>
        <p class="lead">Select an event to purchase tickets</p>
    </div>
</div>

<div class="row">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header @(item.AvailableTickets < 5 ? "bg-warning" : "bg-success text-white")">
                        <h5 class="mb-0">@item.Title</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <strong>Category:</strong>
                            <span class="badge bg-secondary">@item.Category.Name</span>
                        </p>
                        <p class="mb-2"><strong>📅 Date:</strong> @item.DateTime.ToString("MMM dd, yyyy - hh:mm tt")</p>
                        <p class="mb-2"><strong>💵 Price:</strong> $@item.TicketPrice.ToString("F2")</p>
                        <p class="mb-2">
                            <strong>🎫 Available:</strong>
                            @if (item.AvailableTickets < 5)
                            {
                                <span class="badge bg-warning text-dark">@item.AvailableTickets (Limited!)</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@item.AvailableTickets</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Create" asp-route-eventId="@item.EventId" class="btn btn-primary w-100">
                            Purchase Tickets
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-md-12">
            <div class="alert alert-info text-center">
                <h4>No events available</h4>
                <p>All events are currently sold out. Please check back later!</p>
            </div>
        </div>
    }
</div>